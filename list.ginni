{"content":"    \n   <div class=\"list \"   id=\"list\" savrWidType=\"SCREEN\" >\n               <div class=\"list_List\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"list_List_txt\" savrWidType=\"TEXT\" \n         >\n        List\n        \n      </div>\n      \n      </div>\n               <div class=\"list_Top\" savrWidType=\"grid_column\" \n          \n          >\n        \n      </div>\n               <div class=\"list_nav\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"nav_Dashboard\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"list_Dashboard_txt\" savrWidType=\"TEXT\" \n         >\n        Dashboard\n        \n      </div>\n      \n      </div>\n      \n  </div>\n    ","code":"import traceback\nasync def run_main_savr():\n    try:\n        import ginni as g\n         \n        # Set adapter details for list# Generate dummy elements for the adapter. Fetch live data from storage with g.get_item('[SAVED_DATA_KEY]') or make HTTP request with await g.make_request('LIST_DATA_URL') \n        datalist_list_Top = [{'img': 'https://placehold.co/600x400/BBAAAA/BBAAAA/png', 'title': 'nostrud in.', 'subtitle': 'nostrud incididunt esse.'} for x in range(10)]\n        # Populate adapter with data items from adapter template\n        mytemplate_id = 'indicard'\n        adapter_id = 'list_Top'\n        adapter_items_list_Top = []\n        for data in datalist_list_Top:\n            list_item = await g.create_widget_type(template_id=mytemplate_id, parent_id=adapter_id)\n            list_item.get_child('title').set_text_context(data['title'])\n            list_item.get_child('subtitle').set_text_context(data['subtitle'])\n            list_item.get_child('img').set_img_src(data['img'])\n            list_item.set_on_click(lambda e: g.print(f\"Clicked item: {data[\"title\"]}\"))\n            adapter_items_list_Top.append(list_item)\n        # Get reference to all navigation elements and implement navigation to related screen\n        \n        # Get reference to all navigation elements and implement navigation to related screen\n        nav_nav_Dashboard = g.GinNode('nav_Dashboard')\n        nav_nav_Dashboard.set_on_click(lambda e: g.moveto('list'))\n        \n        g.print('rolonng')\n        pgst = g.GinNode('top-progress')\n        pgst.set_visibility(False)\n        g.print('ginniPageLoadMarker8900883612800000')\n    except Exception:\n       consolelogerror(traceback.format_exc())\n\nimport asyncio\nloop = asyncio.get_event_loop()\nresult = loop.run_until_complete(run_main_savr())\n       ","css":"          .list { background: rgba(200, 200, 200, 1); height: 100dvh; width: 100vw;  display:inline-block;overflow-y: scroll;overflow-x: hidden; flex: 0 0 auto;position: relative;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;} \n .list_List { background: rgba(0, 0, 0, 0); height: 30px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;} \n .list_List_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 30px; width: 120px; box-shadow: none; text-align: start; font-size: 15px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 36px;} \n .list_Top { height: 540px; width: 288px; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto; gap: 10px 10px;\n        display: flex;\n        overflow-y: auto;\n       flex-direction: column;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 51px;  left: 12px;} \n .indicard_0 { background: rgba(200, 200, 200, 1); height: 90px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -51px;  left: 1373.9558092522286px;} \n .img_0 { background: rgba(255, 255, 255, 1); height: 81px; width: 91.2px; box-shadow: none; object-fit: cover; background-color: transparent; background-image: url('https://placehold.co/600x400/FFAAFF/FFAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;  left: 6px;} \n .title_0 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(0, 0, 0, 1); height: 36px; width: 123.12px; box-shadow: none; text-align: start; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left