{"content":"    \n   <div class=\"profile_1 \"   id=\"profile_1\" savrWidType=\"SCREEN\" >\n               <div class=\"profile_profile_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"profile_profile_txt_1\" savrWidType=\"TEXT\" \n         >\n        profile\n        \n      </div>\n      \n      </div>\n               <div class=\"Welcome_User__welcome_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"Welcome_User__1\" savrWidType=\"TEXT\" \n         >\n        Welcome User \n        \n      </div>\n               <div class=\"proimg__1\" savrWidType=\"CIRCLE\" \n         >\n        \n        \n      </div>\n               <div class=\"protxt__1\" savrWidType=\"TEXT\" \n         >\n        User name\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Update_info_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Update_info_img_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Update_info_txt_1\" savrWidType=\"TEXT\" \n         >\n        Update info\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Notifications_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Notifications_img_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Notifications_txt_1\" savrWidType=\"TEXT\" \n         >\n        Notifications\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Preferences_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Preferences_img_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Preferences_txt_1\" savrWidType=\"TEXT\" \n         >\n        Preferences\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Security_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Security_img_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Security_txt_1\" savrWidType=\"TEXT\" \n         >\n        Security\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Support_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Support_img_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Support_txt_1\" savrWidType=\"TEXT\" \n         >\n        Support\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_nav_1\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"nav_Dashboard_2\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Dashboard_txt_1\" savrWidType=\"TEXT\" \n         >\n        Dashboard\n        \n      </div>\n      \n      </div>\n      \n  </div>\n    ","code":"import traceback\nasync def run_main_savr():\n    try:\n        import ginni as g\n         # Get reference to all navigation elements and implement navigation to related screen\n        nav_nav_Dashboard_2 = g.GinNode('nav_Dashboard_2')\n        nav_nav_Dashboard_2.set_on_click(lambda e: g.moveto('profile_1'))\n        \n        \n        # Get reference to all settings navigation icon and navigate page to relevant page/form \n        set_set_profile_Update_info_img_1 = g.GinNode('set_profile_Update_info_img_1')\n        set_set_profile_Update_info_img_1.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Notifications_img_1 = g.GinNode('set_profile_Notifications_img_1')\n        set_set_profile_Notifications_img_1.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Preferences_img_1 = g.GinNode('set_profile_Preferences_img_1')\n        set_set_profile_Preferences_img_1.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Security_img_1 = g.GinNode('set_profile_Security_img_1')\n        set_set_profile_Security_img_1.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Support_img_1 = g.GinNode('set_profile_Support_img_1')\n        set_set_profile_Support_img_1.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        \n        # Set profile name text\n        profile_txt = g.GinNode('protxt__1')\n        user_name = 'Profile name' # Alternatively, fetch name from local storage with g.get_item('[SAVED_NAME_KEY]') or call API: await g.make_request('PROFILE_DATA_URL')\n        profile_txt.set_text_context(user_name)\n        # Set profile image\n        profile_img = g.GinNode('proimg__1')\n        # user_img =  g.get_item('[SAVED_IMAGE_URL_KEY]') Fetch image from local storage with g.get_item('[SAVED_IMAGE_URL_KEY]') or call REST API: await g.make_request('PROFILE_DATA_URL')\n        # profile_img.set_img_src(user_img)\n        pgst = g.GinNode('top-progress')\n        pgst.set_visibility(False)\n        g.print('ginniPageLoadMarker8900883612800000')\n    except Exception:\n       consolelogerror(traceback.format_exc())\n\nimport asyncio\nloop = asyncio.get_event_loop()\nresult = loop.run_until_complete(run_main_savr())\n       ","css":"          .profile_1 { background: rgba(200, 200, 200, 1); height: 100dvh; width: 100vw;  display:inline-block;overflow-y: scroll;overflow-x: hidden; flex: 0 0 auto;position: relative;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;} \n .profile_profile_1 { background: rgba(0, 0, 0, 0); height: 30px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;} \n .profile_profile_txt_1 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 30px; width: 120px; box-shadow: none; text-align: start; font-size: 15px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 36px;} \n .Welcome_User__welcome_1 { background: rgba(0, 0, 0, 0); height: 150px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 51px;} \n .Welcome_User__1 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 60px; width: 100%; box-shadow: none; text-align: center; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 600;  display:inline-block;overflow: auto;position: absolute;  top: 12px;} \n .proimg__1 { background: rgba(255, 255, 255, 1); height: 60px; width: 60px; box-shadow: none; background-image: url('https://placehold.co/600x400/FFAAFF/FFAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background