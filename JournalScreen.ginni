{"content":"    \n   <div class=\"JournalScreen \"   id=\"JournalScreen\" savrWidType=\"SCREEN\" >\n               <div class=\"JournalScreen_List\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"JournalScreen_List_txt\" savrWidType=\"TEXT\" \n         >\n        List\n        \n      </div>\n      \n      </div>\n               <div class=\"JournalScreen_Top\" savrWidType=\"grid_column\" \n          \n          >\n        \n      </div>\n               <div class=\"JournalScreen_nav\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"nav_Dashboard_2\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"JournalScreen_Dashboard_txt\" savrWidType=\"TEXT\" \n         >\n        Dashboard\n        \n      </div>\n      \n      </div>\n      \n  </div>\n    ","code":"import traceback\nasync def run_main_savr():\n    try:\n        import ginni as g\n        \n        async def initialize_journal():\n            # Realistic transaction data for a bookkeeping app\n            transactions = [\n                {\"title\": \"Office Rent - Oct\", \"subtitle\": \"-$2,500.00 | 2023-10-01\", \"img\": \"https://img.icons8.com/color/96/home.png\", \"notes\": \"Monthly office lease payment.\", \"status\": \"Cleared\"},\n                {\"title\": \"Client Invoice #1024\", \"subtitle\": \"+$4,250.00 | 2023-10-03\", \"img\": \"https://img.icons8.com/color/96/checked-user-male.png\", \"notes\": \"Payment from Acme Corp for Q3 consulting.\", \"status\": \"Pending\"},\n                {\"title\": \"Staples Supplies\", \"subtitle\": \"-$124.50 | 2023-10-05\", \"img\": \"https://img.icons8.com/color/96/box.png\", \"notes\": \"Printer ink and stationery.\", \"status\": \"Cleared\"},\n                {\"title\": \"AWS Hosting Fee\", \"subtitle\": \"-$89.00 | 2023-10-07\", \"img\": \"https://img.icons8.com/color/96/amazon-web-services.png\", \"notes\": \"Server costs for production environment.\", \"status\": \"Cleared\"},\n                {\"title\": \"Consulting Fee - XYZ\", \"subtitle\": \"+$1,500.00 | 2023-10-10\", \"img\": \"https://img.icons8.com/color/96/conference-call.png\", \"notes\": \"One-day strategy workshop.\", \"status\": \"Cleared\"}\n            ]\n        \n            adapter_id = 'JournalScreen_Top'\n            template_id = 'indicard_9'\n            \n            # Update Header\n            g.GinNode('JournalScreen_List_txt').set_text_context(\"General Journal\")\n        \n            # Clear and populate the adapter\n            for data in transactions:\n                # Create entry from template\n                list_item = await g.create_widget_type(template_id=template_id, parent_id=adapter_id)\n                \n                # Map data to widgets\n                list_item.get_child('title_9').set_text_context(data['title'])\n                list_item.get_child('subtitle_8').set_text_context(data['subtitle'])\n                list_item.get_child('img_7').set_img_src(data['img'])\n                \n                # Interaction: Detail view\n                def show_details(d=data):\n                    async def on_click(e):\n                        # Create buttons for the drawup\n                        btn_close = g.Ginton(\"Close\", \"#666666\", lambda ev: g.close_overlay())\n                        btn_edit = g.Ginton(\"Edit Entry\", \"#FF5E00\", lambda ev: g.show_toast(\"Edit functionality coming soon.\"))\n                        \n                        g.open_drawup(\n                            title=d['title'],\n                            details=f\"Summary: {d['subtitle']}\\nStatus: {d['status']}\\n\\nNotes: {d['notes']}\",\n                            buttons=[btn_edit, btn_close]\n                        )\n                    return on_click\n                    \n                list_item.set_on_click(show_details(data))\n                # Also bind to text elements for better accessibility\n                list_item.get_child('title_9').set_on_click(show_details(data))\n        \n            # Bottom Navigation Logic\n            nav_dashboard = g.GinNode('nav_Dashboard_2')\n            nav_dashboard_txt = g.GinNode('JournalScreen_Dashboard_txt')\n        \n            async def go_to_dashboard(e):\n                g.moveto('DashboardScreen')\n        \n            nav_dashboard.set_on_click(go_to_dashboard)\n            nav_dashboard_txt.set_on_click(go_to_dashboard)\n        \n        # Execute initialization\n        await initialize_journal()\n        pgst = g.GinNode('top-progress')\n        pgst.set_visibility(False)\n        g.print('ginniPageLoadMarker8900883612800000')\n    except Exception:\n       consolelogerror(traceback.format_exc())\n\nimport asyncio\nloop = asyncio.get_event_loop()\nresult = loop.run_until_complete(run_main_savr())\n       ","css":"          .JournalScreen { background: rgba(248, 250, 252, 1); height: 100dvh; width: 100vw;  display:inline-block;overflow-y: scroll;overflow-x: hidden; flex: 0 0 auto;position: relative;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;} \n .JournalScreen_List { background: rgba(0, 0, 0, 0); height: 30px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;} \n .JournalScreen_List_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(255, 94, 0, 1); height: 30px; width: 120px; box-shadow: none; text-align: start; font-size: 15px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 36px;} \n .JournalScreen_Top { height: 540px; width: 288px; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto; gap: 10px 10px;\n        display: flex;\n        overflow-y: auto;\n       flex-direction: column;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 51px;  left: 12px;} \n .indicard_24 { background: rgba(248, 250, 252, 1); height: 90px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -51px;  left: 3822px;} \n .img_18 { background: rgba(255, 255, 255, 1); height: 81px; width: 91.2px; box-shadow: none; object-fit: cover; background-color: transparent; background-image: url('https://placehold.co/600x400/FFAAFF/FFAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;  left: 6px;} \n .title_24 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(