ckground-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 400;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 30px;} \n .profile_Security { background: rgba(0, 0, 0, 0); height: 24px; width: 180px; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.09); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0.6px solid rgba(40, 53, 147, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: 351px;  left: calc(50% + -78px);} \n .set_profile_Security_img { background: rgba(40, 53, 147, 1); height: 12px; width: 12px; box-shadow: none; object-fit: contain; filter: invert(41%) sepia(99%) saturate(4.03) hue-rotate(195deg) brightness(0.56) contrast(1.26); background-color: transparent; background-image: url('https://storage.googleapis.com/savr-1c4c5.appspot.com/icons/Lock.png'); text-align: start; font-size: 12px; background-size:  contain; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 3px;  left: 3px;} \n .profile_Security_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 16.8px; width: 120px; box-shadow: none; text-align: start; font-size: 8.4px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: