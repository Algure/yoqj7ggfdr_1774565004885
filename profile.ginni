{"content":"    \n   <div class=\"profile \"   id=\"profile\" savrWidType=\"SCREEN\" >\n               <div class=\"profile_profile\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"profile_profile_txt\" savrWidType=\"TEXT\" \n         >\n        profile\n        \n      </div>\n      \n      </div>\n               <div class=\"Welcome_User__welcome\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"Welcome_User_\" savrWidType=\"TEXT\" \n         >\n        Welcome User \n        \n      </div>\n               <div class=\"proimg_\" savrWidType=\"CIRCLE\" \n         >\n        \n        \n      </div>\n               <div class=\"protxt_\" savrWidType=\"TEXT\" \n         >\n        User name\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Update_info\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Update_info_img\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Update_info_txt\" savrWidType=\"TEXT\" \n         >\n        Update info\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Notifications\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Notifications_img\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Notifications_txt\" savrWidType=\"TEXT\" \n         >\n        Notifications\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Preferences\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Preferences_img\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Preferences_txt\" savrWidType=\"TEXT\" \n         >\n        Preferences\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Security\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Security_img\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Security_txt\" savrWidType=\"TEXT\" \n         >\n        Security\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_Support\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"set_profile_Support_img\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Support_txt\" savrWidType=\"TEXT\" \n         >\n        Support\n        \n      </div>\n      \n      </div>\n               <div class=\"profile_nav\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"nav_Dashboard_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"profile_Dashboard_txt\" savrWidType=\"TEXT\" \n         >\n        Dashboard\n        \n      </div>\n      \n      </div>\n      \n  </div>\n    ","code":"import traceback\nasync def run_main_savr():\n    try:\n        import ginni as g\n         # Get reference to all navigation elements and implement navigation to related screen\n        nav_nav_Dashboard_1 = g.GinNode('nav_Dashboard_1')\n        nav_nav_Dashboard_1.set_on_click(lambda e: g.moveto('profile'))\n        \n        \n        # Get reference to all settings navigation icon and navigate page to relevant page/form \n        set_set_profile_Update_info_img = g.GinNode('set_profile_Update_info_img')\n        set_set_profile_Update_info_img.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Notifications_img = g.GinNode('set_profile_Notifications_img')\n        set_set_profile_Notifications_img.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Preferences_img = g.GinNode('set_profile_Preferences_img')\n        set_set_profile_Preferences_img.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Security_img = g.GinNode('set_profile_Security_img')\n        set_set_profile_Security_img.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        set_set_profile_Support_img = g.GinNode('set_profile_Support_img')\n        set_set_profile_Support_img.set_on_click(lambda e: g.moveto('[FORM_SCREEN_NAME]'))\n        \n        \n        # Set profile name text\n        profile_txt = g.GinNode('protxt_')\n        user_name = 'Profile name' # Alternatively, fetch name from local storage with g.get_item('[SAVED_NAME_KEY]') or call API: await g.make_request('PROFILE_DATA_URL')\n        profile_txt.set_text_context(user_name)\n        # Set profile image\n        profile_img = g.GinNode('proimg_')\n        # user_img =  g.get_item('[SAVED_IMAGE_URL_KEY]') Fetch image from local storage with g.get_item('[SAVED_IMAGE_URL_KEY]') or call REST API: await g.make_request('PROFILE_DATA_URL')\n        # profile_img.set_img_src(user_img)\n        pgst = g.GinNode('top-progress')\n        pgst.set_visibility(False)\n        g.print('ginniPageLoadMarker8900883612800000')\n    except Exception:\n       consolelogerror(traceback.format_exc())\n\nimport asyncio\nloop = asyncio.get_event_loop()\nresult = loop.run_until_complete(run_main_savr())\n       ","css":"          .profile { background: rgba(200, 200, 200, 1); height: 100dvh; width: 100vw;  display:inline-block;overflow-y: scroll;overflow-x: hidden; flex: 0 0 auto;position: relative;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;} \n .profile_profile { background: rgba(0, 0, 0, 0); height: 30px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;} \n .profile_profile_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 30px; width: 120px; box-shadow: none; text-align: start; font-size: 15px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 36px;} \n .Welcome_User__welcome { background: rgba(0, 0, 0, 0); height: 150px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 51px;} \n .Welcome_User_ {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 60px; width: 100%; box-shadow: none; text-align: center; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 600;  display:inline-block;overflow: auto;position: absolute;  top: 12px;} \n .proimg_ { background: rgba(255, 255, 255, 1); height: 60px; width: 60px; box-shadow: none; background-image: url('https://placehold.co/600x400/FFAAFF/FFAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto; border-radius: 50%;position: absolute;  top: 60px;  left: calc(50% + -30px);} \n .protxt_ {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(0, 0, 0, 1); height: 30px; width: 120px; box-shadow: none; text-align: center; font-size: 9.6px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;position: absolute;  top: 126px;  left: calc(50% + -60px);} \n .profile_Update_info { background: rgba(0, 0, 0, 0); height: 24px; width: 180px; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.09); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0.6px solid rgba(40, 53, 147, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: 216px;  left: calc(50% + -78px);} \n .set_profile_Update_info_img { background: rgba(40, 53, 147, 1); height: 12px; width: 12px; box-shadow: none; object-fit: contain; filter: invert(61%) sepia(46%) saturate(3.87) hue-rotate(195deg) brightness(0.54) contrast(2.00); background-color: transparent; background-image: url('https://storage.googleapis.com/savr-1c4c5.appspot.com/icons/Info.png'); text-align: start; font-size: 12px; background-size:  contain; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 3px;  left: 3px;} \n .profile_Update_info_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 147, 1); height: 16.8px; width: 120px; box-shadow: none; text-align: start; font-size: 8.4px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 400;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 30px;} \n .profile_Notifications { background: rgba(0, 0, 0, 0); height: 24px; width: 180px; box-shadow: 0px 4px 8px 0px rgba(0, 0, 0, 0.09); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0.6px solid rgba(40, 53, 147, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: 261px;  left: calc(50% + -78px);} \n .set_profile_Notifications_img { background: rgba(40, 53, 147, 1); height: 12px; width: 12px; box-shadow: none; object-fit: contain; filter: invert(61%) sepia(38%) saturate(4.21) hue-rotate(195deg) brightness(0.56) contrast(2.13); background-color: transparent; background-image: url('https://storage.googleapis.com/savr-1c4c5.appspot.com/icons/Bell.png'); text-align: start; font-size: 12px; background-size:  contain; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 3px;  left: 3px;} \n .profile_Notifications_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(40, 53, 14