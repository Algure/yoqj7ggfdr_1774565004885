ound-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;background: transparent;--graph-color: #FF5E00;  display:inline-block;overflow: auto;border:0px solid rgba(255, 94, 0, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 30px;} \n .txt_Das {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(28, 28, 30, 1); height: 36px; width: 228px; box-shadow: none; text-align: start; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 800;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 429px;  left: calc(50% + -117px);} \n .DashboardScreen_Trades { height: 420px; width: 288px; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto; gap: 10px 10px;\n        display: flex;\n        overflow-y: auto;\n       flex-direction: column;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 474px;  left: 3px;} \n .indicard_14 { background: rgba(248, 250, 252, 1); height: 60px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -474px;  left: 1275px;} \n .title_14 {white-space: normal