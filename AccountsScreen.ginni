ine-block;overflow: auto;position: absolute;  top: 27px;  left: 103.2px;} \n .indicard_23 { background: rgba(248, 250, 252, 1); height: 90px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -51px;  left: 2544px;} \n .img_17 { background: rgba(255, 255, 255, 1); height: 81px; width: 91.2px; box-shadow: none; object-fit: cover; background-color: transparent; background-image: url('https://placehold.co/600x400/AAAAFF/AAAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;  left: 6px;} \n .title_23 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(28, 28, 30, 1); height: 36px; width: 123.12px; box-shadow: none; text-align: start; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 800;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 103.2px;} \n .subtitle_22 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(28, 28, 30, 0.588235294117