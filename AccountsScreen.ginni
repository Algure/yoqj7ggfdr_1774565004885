{"content":"    \n   <div class=\"AccountsScreen \"   id=\"AccountsScreen\" savrWidType=\"SCREEN\" >\n               <div class=\"AccountsScreen_List\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"AccountsScreen_List_txt\" savrWidType=\"TEXT\" \n         >\n        List\n        \n      </div>\n      \n      </div>\n               <div class=\"AccountsScreen_Top\" savrWidType=\"grid_column\" \n          \n          >\n        \n      </div>\n               <div class=\"AccountsScreen_nav\" savrWidType=\"RECT\" \n         >\n        \n                 <div class=\"nav_Dashboard_1\"   savrWidType=\"IMAGE\"  >\n             \n      </div>\n               <div class=\"AccountsScreen_Dashboard_txt\" savrWidType=\"TEXT\" \n         >\n        Dashboard\n        \n      </div>\n      \n      </div>\n      \n  </div>\n    ","code":"import traceback\nasync def run_main_savr():\n    try:\n        import ginni as g\n        \n        # Set Header Text\n        g.GinNode('AccountsScreen_List_txt').set_text_context('Chart of Accounts')\n        \n        # Realistic Data for Chart of Accounts\n        accounts_data = [\n            {'name': 'Cash at Bank', 'type': 'Asset', 'balance': '$12,450.00', 'img': 'https://img.icons8.com/fluency/96/bank.png'},\n            {'name': 'Accounts Receivable', 'type': 'Asset', 'balance': '$4,200.00', 'img': 'https://img.icons8.com/fluency/96/invoice.png'},\n            {'name': 'Office Equipment', 'type': 'Asset', 'balance': '$8,000.00', 'img': 'https://img.icons8.com/fluency/96/monitor.png'},\n            {'name': 'Accounts Payable', 'type': 'Liability', 'balance': '$1,150.00', 'img': 'https://img.icons8.com/fluency/96/supplier.png'},\n            {'name': 'Business Credit Card', 'type': 'Liability', 'balance': '$2,400.00', 'img': 'https://img.icons8.com/fluency/96/credit-card.png'},\n            {'name': 'Owner Equity', 'type': 'Equity', 'balance': '$20,000.00', 'img': 'https://img.icons8.com/fluency/96/conference-call.png'},\n            {'name': 'Product Sales', 'type': 'Revenue', 'balance': '$35,200.00', 'img': 'https://img.icons8.com/fluency/96/sales-performance.png'},\n            {'name': 'Office Rent', 'type': 'Expense', 'balance': '$2,500.00', 'img': 'https://img.icons8.com/fluency/96/rent.png'},\n            {'name': 'Utilities', 'type': 'Expense', 'balance': '$450.00', 'img': 'https://img.icons8.com/fluency/96/light-on.png'}\n        ]\n        \n        async def show_account_details(account):\n            # Action handler for the Edit button\n            async def edit_handler(e):\n                g.show_toast(f'Editing {account[\"name\"]}...')\n        \n            # Action buttons for the drawup\n            btns = [\n                g.Ginton('Edit Account', '#4A90E2', edit_handler),\n                g.Ginton('Close', '#666', lambda e: g.close_overlay())\n            ]\n            g.open_drawup(\n                image=account['img'],\n                title=account['name'],\n                details=f\"Category: {account['type']}\\nCurrent Balance: {account['balance']}\\nLast reconciled: Today\",\n                buttons=btns\n            )\n        \n        async def load_accounts():\n            mytemplate_id = 'indicard_8'\n            adapter_id = 'AccountsScreen_Top'\n            \n            for data in accounts_data:\n                # Create widget instance from template\n                list_item = await g.create_widget_type(template_id=mytemplate_id, parent_id=adapter_id)\n                \n                # Map data to template widgets\n                list_item.get_child('title_8').set_text_context(data['name'])\n                list_item.get_child('subtitle_7').set_text_context(f\"{data['type']} • {data['balance']}\")\n                list_item.get_child('img_6').set_img_src(data['img'])\n                \n                # Define and bind an async click handler\n                async def click_handler(e, acc=data):\n                    await show_account_details(acc)\n                    \n                list_item.set_on_click(click_handler)\n        \n        # Navigation Implementation\n        g.GinNode('nav_Dashboard_1').set_on_click(lambda e: g.moveto('DashboardScreen'))\n        g.GinNode('AccountsScreen_Dashboard_txt').set_on_click(lambda e: g.moveto('DashboardScreen'))\n        \n        # Run the loader using top-level await\n        await load_accounts()\n        pgst = g.GinNode('top-progress')\n        pgst.set_visibility(False)\n        g.print('ginniPageLoadMarker8900883612800000')\n    except Exception:\n       consolelogerror(traceback.format_exc())\n\nimport asyncio\nloop = asyncio.get_event_loop()\nresult = loop.run_until_complete(run_main_savr())\n       ","css":"          .AccountsScreen { background: rgba(248, 250, 252, 1); height: 100dvh; width: 100vw;  display:inline-block;overflow-y: scroll;overflow-x: hidden; flex: 0 0 auto;position: relative;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;} \n .AccountsScreen_List { background: rgba(0, 0, 0, 0); height: 30px; width: 100%; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;} \n .AccountsScreen_List_txt {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(255, 94, 0, 1); height: 30px; width: 120px; box-shadow: none; text-align: start; font-size: 15px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 700;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 36px;} \n .AccountsScreen_Top { height: 540px; width: 288px; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto; gap: 10px 10px;\n        display: flex;\n        overflow-y: auto;\n       flex-direction: column;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 51px;  left: 12px;} \n .indicard_18 { background: rgba(248, 250, 252, 1); height: 90px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -51px;  left: 2544px;} \n .img_12 { background: rgba(255, 255, 255, 1); height: 81px; width: 91.2px; box-shadow: none; object-fit: cover; background-color: transparent; background-image: url('https://placehold.co/600x400/AAAAFF/AAAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;  left: 6px;} \n .title_18 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(28, 28, 30, 1); height: 36px; width: 123.12px; box-shadow: none; text-align: start; font-size: 18px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 800;  display:inline-block;overflow: auto;overflow-y: hidden;overflow-x: hidden; white-space: nowrap; text-overflow: ellipsis;position: absolute;  top: 6px;  left: 103.2px;} \n .subtitle_17 {white-space: normal;\n  word-wrap: break-word;\n  overflow-wrap: break-word; background: transparent; background-color: transparent; border: none; resize: none; color: rgba(28, 28, 30, 0.5882352941176471); height: 42px; width: 123.12px; box-shadow: none; text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  font-weight: 400;  display:inline-block;overflow: auto;position: absolute;  top: 27px;  left: 103.2px;} \n .indicard_19 { background: rgba(248, 250, 252, 1); height: 90px; width: 228px; box-shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.07); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 2.4px 2.4px 2.4px 2.4px;position: absolute;  top: -51px;  left: 2544px;} \n .img_13 { background: rgba(255, 255, 255, 1); height: 81px; width: 91.2px; box-shadow: none; object-fit: cover; background-color: transparent; background-image: url('https://placehold.co/600x400/AAAAFF/AAAAFF/png'); text-align: start; font-size: 12px; background-size:  cover; background-repeat: no-repeat; background-position: center center; margin-top: 0px; margin-bottom: 0px; margin-right: 0px; margin-left: 0px;  display:inline-block;overflow: auto;border:0px solid rgba(255, 255, 255, 1);border-radius: 0px 0px 0px 0px;position: absolute;  top: 6px;  left: 6px;} \n .title